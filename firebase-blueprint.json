{
  "entities": {
    "user": {
      "title": "User",
      "description": "Represents a South African client or doer on the marketplace",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "firstName": {
          "type": "string"
        },
        "middleName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "phoneNumber": {
          "type": "string"
        },
        "physicalAddress": {
          "type": "string"
        },
        "city": {
          "type": "string"
        },
        "province": {
          "type": "string"
        },
        "profileImageUrl": {
          "type": "string"
        },
        "verificationStatus": {
          "type": "string"
        },
        "profileCompleted": {
          "type": "boolean"
        },
        "onboardingCompleted": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "uid",
        "email",
        "firstName",
        "lastName",
        "phoneNumber",
        "physicalAddress",
        "city",
        "province",
        "profileImageUrl"
      ]
    },
    "doer_profile": {
      "title": "Doer Profile",
      "description": "Consolidated service provider metadata, including legacy skills, languages, and ratings",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "bio": {
          "type": "string"
        },
        "occupation": {
          "type": "string"
        },
        "yearsOfExperience": {
          "type": "number"
        },
        "education": {
          "type": "string"
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "languages": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "categories": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "servicesOffered": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "hourlyRate": {
          "type": "number"
        },
        "verificationStatus": {
          "type": "string"
        },
        "isActive": {
          "type": "boolean"
        },
        "averageRating": {
          "type": "number"
        },
        "completedJobsCount": {
          "type": "number"
        },
        "reviewCount": {
          "type": "number"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "trustScore": {
          "type": "object",
          "properties": {
            "score": {
              "type": "number"
            },
            "level": {
              "type": "string"
            },
            "verificationScore": {
              "type": "number"
            },
            "reputationScore": {
              "type": "number"
            },
            "reliabilityScore": {
              "type": "number"
            },
            "activityScore": {
              "type": "number"
            }
          }
        }
      },
      "required": [
        "uid",
        "userId",
        "displayName",
        "bio",
        "occupation",
        "yearsOfExperience",
        "education",
        "skills",
        "languages",
        "categories",
        "servicesOffered",
        "hourlyRate"
      ]
    },
    "user_verification": {
      "title": "User Verification",
      "description": "Secure storage of identity verification documents",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string"
        },
        "governmentIdUrl": {
          "type": "string"
        },
        "proofOfAddressUrl": {
          "type": "string"
        },
        "backgroundCheckStatus": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "uid",
        "backgroundCheckStatus"
      ]
    },
    "notification": {
      "title": "Notification",
      "description": "System or user-generated notification",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "isRead": {
          "type": "boolean"
        },
        "actionUrl": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "title",
        "message",
        "type",
        "isRead",
        "createdAt"
      ]
    },
    "saved_item": {
      "title": "Saved Item",
      "description": "Represents a listing (service, product, or doer) saved as a favorite by a user",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "itemId": {
          "type": "string"
        },
        "itemType": {
          "type": "string",
          "enum": [
            "service",
            "product",
            "doer"
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "userId",
        "itemId",
        "itemType"
      ]
    },
    "review": {
      "title": "Review",
      "description": "User review and rating for a doer",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "targetId": {
          "type": "string"
        },
        "authorName": {
          "type": "string"
        },
        "authorAvatar": {
          "type": "string"
        },
        "rating": {
          "type": "number"
        },
        "comment": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "authorId": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "targetId",
        "rating",
        "comment",
        "createdAt",
        "authorId"
      ]
    },
    "service_request": {
      "title": "Service Request",
      "description": "Represents a booking or order request between a client and a doer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "serviceId": { "type": ["string", "null"] },
        "productId": { "type": ["string", "null"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "depositAmount": { "type": "number" },
        "bookingOwnerName": { "type": "string" },
        "bookingOwnerAvatar": { "type": "string" },
        "bookingOwnerId": { "type": "string" },
        "doerId": { "type": "string" },
        "doerName": { "type": "string" },
        "location": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "disputeReason": { "type": "string" },
        "isProductOrder": { "type": "boolean" }
      },
      "required": [
        "id",
        "title",
        "description",
        "price",
        "bookingOwnerId",
        "doerId",
        "status",
        "createdAt",
        "updatedAt"
      ]
    },
    "conversations": {
      "title": "Conversations",
      "description": "Represents chat channels between users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "bookingOwnerId": { "type": "string" },
        "bookingOwnerName": { "type": "string" },
        "bookingOwnerAvatar": { "type": "string" },
        "doerId": { "type": "string" },
        "doerName": { "type": "string" },
        "doerAvatar": { "type": "string" },
        "lastMessageText": { "type": "string" },
        "lastMessageTime": { "type": "string" },
        "unreadCount": { "type": "number" }
      },
      "required": [
        "id",
        "bookingOwnerId",
        "doerId"
      ]
    },
    "messages": {
      "title": "Messages",
      "description": "Represents chat messages between a booking owner and a doer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "conversationId": { "type": "string" },
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "imageUrl": { "type": ["string", "null"] },
        "createdAt": { "type": "string" },
        "timestamp": { "type": ["string", "object"] },
        "jobUpdateStatus": { "type": ["string", "null"] },
        "jobUpdateAmount": { "type": ["number", "null"] },
        "bookingOwnerId": { "type": "string" },
        "doerId": { "type": "string" },
        "typing": { "type": "boolean" },
        "read": { "type": "boolean" }
      },
      "required": [
        "id",
        "conversationId",
        "senderId",
        "receiverId",
        "text"
      ]
    },
    "p2p_transfer": {
      "title": "P2P Transfer",
      "description": "Represents an instant wallet-to-wallet funds transfer between users",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "senderId": {
          "type": "string"
        },
        "senderName": {
          "type": "string"
        },
        "recipientId": {
          "type": "string"
        },
        "recipientName": {
          "type": "string"
        },
        "amount": {
          "type": "number"
        },
        "reference": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "senderId",
        "senderName",
        "recipientId",
        "recipientName",
        "amount",
        "reference",
        "createdAt"
      ]
    },
    "platform_settings": {
      "title": "Platform Settings",
      "description": "Global platform configurations",
      "type": "object",
      "properties": {
        "serviceFee": {
          "type": "number"
        }
      },
      "required": [
        "serviceFee"
      ]
    },
    "service_fee_history": {
      "title": "Service Fee History",
      "description": "Log of service fee changes",
      "type": "object",
      "properties": {
        "feeName": { "type": "string" },
        "previousFee": { "type": "number" },
        "newFee": { "type": "number" },
        "reason": { "type": "string" },
        "updatedAt": { "type": "string" },
        "updatedBy": { "type": "string" }
      }
    },
    "service_fee_config": {
      "title": "Service Fee Configuration",
      "description": "Configuration for a service fee",
      "type": "object",
      "properties": {
        "feeName": { "type": "string" },
        "amount": { "type": "number" },
        "updatedAt": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "user",
      "description": "Primary user profile information"
    },
    "/doer_profiles/{uid}": {
      "schema": "doer_profile",
      "description": "Consolidated provider/doer details"
    },
    "/user_verifications/{uid}": {
      "schema": "user_verification",
      "description": "Sensitive verification records and file links"
    },
    "/notifications/{notificationId}": {
      "schema": "notification",
      "description": "System or user-generated notifications"
    },
    "/saved_items/{savedItemId}": {
      "schema": "saved_item",
      "description": "User saved favorites (services, products, or doers)"
    },
    "/reviews/{reviewId}": {
      "schema": "review",
      "description": "User reviews of doers"
    },
    "/service_requests/{requestId}": {
      "schema": "service_request",
      "description": "Booking and order requests"
    },
    "/conversations/{conversationId}": {
      "schema": "conversations",
      "description": "Chat channels between booking owners and doers"
    },
    "/messages/{messageId}": {
      "schema": "messages",
      "description": "Individual chat messages"
    },
    "/p2p_transfers/{transferId}": {
      "schema": "p2p_transfer",
      "description": "Wallet-to-wallet instant peer payments"
    },
    "/settings/platformConfig": {
      "schema": "platform_settings",
      "description": "Global platform configurations"
    },
    "/service_fees/{feeId}": {
      "schema": "service_fee_config",
      "description": "Configured service fees"
    },
    "/service_fee_history/{historyId}": {
      "schema": "service_fee_history",
      "description": "History of fee changes"
    }
  }
}